# ─── LLM provider ───────────────────────────────────────────────────────────
# Set ONE of the two keys below. If both are set, Gemini wins by default.
# Override with LLM_PROVIDER=anthropic|gemini if you want explicit control.

# Anthropic (paid — uses console.anthropic.com credits, NOT the Claude Code subscription)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (free tier on 2.0 Flash : 15 req/min, 1500/day)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Force a provider explicitly (optional)
# LLM_PROVIDER=gemini

# ─── Delivery ───────────────────────────────────────────────────────────────
DIGEST_RECIPIENT=xvironneau@gmail.com
