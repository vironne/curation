{
  "name": "business-digest",
  "version": "0.1.0",
  "private": true,
  "description": "Weekly digests pipeline — Curation Weekly (Monday 8am) + Business Ideas Weekly (Wednesday 9am)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "combined": "tsx src/combined/index.ts",
    "curation": "tsx src/curation/index.ts",
    "business-ideas": "tsx src/business-ideas/index.ts",
    "dev:combined": "tsx src/combined/index.ts --dry-run --fixtures",
    "dev:curation": "tsx src/curation/index.ts --dry-run --fixtures",
    "dev:business-ideas": "tsx src/business-ideas/index.ts --dry-run --fixtures",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
